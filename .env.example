# =========================
# Pluggy credentials (required)
# =========================

# Pluggy API client id; obtain from your Pluggy dashboard (Settings > API).
PLUGGY_CLIENT_ID=your-client-id-here
# Pluggy API client secret; treat as a password — never commit a real value.
PLUGGY_CLIENT_SECRET=your-client-secret-here

# =========================
# Security toggles (safe defaults — opt OUT only if you know why)
# =========================

# Mask PII (CPF, account numbers, owner names, payer/receiver) before it
# reaches the LLM context. Set to "false" to disable (logs a startup WARN).
PLUGGY_MCP_REDACT=true
# Emit one JSON-line audit event per tool call to stderr. Set to "false"
# to disable non-sensitive audit lines (sensitive events are unbypassable).
PLUGGY_MCP_AUDIT=true
# Enforce in-memory per-tool rate limits. Set to "false" to disable;
# leaves your Pluggy quota fully exposed to runaway agents.
PLUGGY_MCP_RATELIMIT=true
# Per-tool budget over a 60-second sliding window. Default: 30.
PLUGGY_MCP_RATELIMIT_PER_MIN=30
# Per-tool budget over a 24-hour sliding window. Default: 200.
PLUGGY_MCP_RATELIMIT_PER_DAY=200
# When "1", classifyAndReport also dumps the raw upstream error (body +
# stack) to stderr — useful for active debugging, off by default because
# the body can contain customer data.
PLUGGY_MCP_DEBUG=0

# =========================
# Items scoping (optional — leave empty for no restriction)
# =========================

# Comma-separated Pluggy Item UUIDs the operator wants this server scoped
# to. When set, item-scoped tools (getItem, listConsents, ...) refuse any
# itemId not in this list with a FORBIDDEN envelope — no upstream call is
# made. Empty or unset means "no restriction".
PLUGGY_ITEM_IDS=
